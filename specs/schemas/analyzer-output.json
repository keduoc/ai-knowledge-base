{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-knowledge-base/schemas/analyzer-output.json",
  "title": "Analyzer Output",
  "description": "分析 Agent 产出的结构化数据格式，每条为经打标、摘要、评分后的技术条目。",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "title", "url", "source", "popularity", "summary", "tags", "score", "score_reason"],
    "properties": {
      "id": {
        "type": "string",
        "description": "原始条目的序号或唯一标识"
      },
      "title": {
        "type": "string",
        "description": "原始标题",
        "minLength": 1
      },
      "url": {
        "type": "string",
        "format": "uri",
        "description": "完整链接",
        "pattern": "^https?://"
      },
      "source": {
        "type": "string",
        "enum": ["github-trending", "hackernews"],
        "description": "来源标识"
      },
      "popularity": {
        "type": "integer",
        "minimum": 0,
        "description": "原始热度值"
      },
      "summary": {
        "type": "string",
        "description": "中文摘要，≤200 字",
        "maxLength": 200
      },
      "tags": {
        "type": "array",
        "description": "2-5 个标签，必须来自预定义标签池",
        "minItems": 2,
        "maxItems": 5,
        "items": {
          "type": "string",
          "enum": [
            "LLM", "VLM", "SLM", "MoE", "RAG", "Fine-tuning", "Prompt-Engineering",
            "Agent", "Copilot", "Chatbot", "Code-Generation", "Search", "Translation",
            "Vector-DB", "Inference-Framework", "MLOps", "Data-Pipeline",
            "Open-Source", "Open-Weights", "Proprietary",
            "NLP", "CV", "Speech", "Multimodal", "Robotics",
            "Chinese", "English", "Multilingual",
            "Benchmark", "Survey", "Tutorial", "Paper"
          ]
        }
      },
      "score": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10,
        "description": "质量评分 1-10"
      },
      "score_reason": {
        "type": "string",
        "description": "一句话评分依据",
        "minLength": 1
      }
    },
    "additionalProperties": false
  }
}
